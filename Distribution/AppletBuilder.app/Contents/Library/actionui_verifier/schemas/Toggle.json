{
  "type": "Toggle",
  "description": "On/off switch",
  "id": { "policy": "optional" },
  "inheritsViewProperties": true,
  "topLevelKeys": [],
  "ownProperties": {
    "isOn":  { "types": ["boolean"], "required": false, "description": "Initial on/off state; defaults to false" },
