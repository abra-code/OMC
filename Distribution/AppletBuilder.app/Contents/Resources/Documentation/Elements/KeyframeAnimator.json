{
  "type": "KeyframeAnimator",
  "content": {
    "type": "Text",
    "properties": {
      "text": "Animating"
    }
  },
  "properties": {
    "initialValue": {
      "opacity": 0.0,
      "scale": 1.0
    },
    "trigger": "onAppear",
    "repeat": {
      "count": 3,
      "autoreverses": true
    },
    "keyframes": {
      "0%": {
        "type": "linear",
        "value": {
          "opacity": 0.0,
          "scale": 0.5
        },
        "duration": 0.8
      },
      "100%": {
        "type": "spring",
        "value": {
          "opacity": 1.0,
          "scale": 1.0
        },
        "duration": 0.5,
        "response": 0.4,
        "dampingRatio": 0.6
      }
    }
  }
}
